# Repository line endings: LF only. Pair with local: git config core.autocrlf false
# and EditorConfig / VS Code settings so Windows editors do not reintroduce CRLF.

* text=auto eol=lf

*.sh text eol=lf
*.bash text eol=lf
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.env text eol=lf
Dockerfile text eol=lf

# Binary assets — do not apply text/CRLF normalization
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary
*.zip binary
*.gz binary
*.7z binary
*.wasm binary
*.mp4 binary
*.webm binary
*.mp3 binary
*.wav binary
